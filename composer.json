{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "kokonut-ch/laravel-swiss-bank-csv-parser",
    "description": "Laravel Package | Parse CSV account statements exported by Swiss banks into one neutral, predictable structure.",
    "keywords": [
        "laravel",
        "csv",
        "bank",
        "bank-statement",
        "switzerland",
        "iso-20022"
    ],
    "homepage": "https://github.com/Kokonut-ch/SwissBankCsvParser",
    "license": "MIT",
    "authors": [
        {
            "name": "Kokonut",
            "email": "dev@kokonut.ch",
            "homepage": "https://kokonut.ch",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0||^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.29",
        "laravel/pao": "^1.0",
        "orchestra/testbench": "^10.0||^11.0",
        "pestphp/pest": "^4.6",
        "pestphp/pest-plugin-laravel": "^4.1",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "phpstan/extension-installer": "^1.4"
    },
    "autoload": {
        "psr-4": {
            "Kokonut\\SwissBankCsvParser\\": "src/",
            "Kokonut\\SwissBankCsvParser\\Banks\\": "banks/"
        },
        "exclude-from-classmap": [
            "banks/*/tests/",
            "banks/*/fixtures/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Kokonut\\SwissBankCsvParser\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "prepare": [
            "@php vendor/bin/testbench package:discover --ansi"
        ],
        "build": [
            "@php vendor/bin/testbench workbench:build --ansi"
        ],
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "lint": [
            "vendor/bin/pint --parallel"
        ],
        "lint:check": [
            "vendor/bin/pint --parallel --test"
        ],
        "analyse": [
            "vendor/bin/phpstan analyse"
        ],
        "test:types": [
            "vendor/bin/pest --type-coverage --min=100"
        ],
        "test:unit": [
            "vendor/bin/pest --parallel"
        ],
        "test": [
            "@analyse",
            "@lint:check",
            "@test:types",
            "@test:unit"
        ],
        "clear": [
            "@php vendor/bin/testbench package:purge-skeleton --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kokonut\\SwissBankCsvParser\\SwissBankCsvParserServiceProvider"
            ],
            "aliases": {
                "SwissBankCsvParser": "Kokonut\\SwissBankCsvParser\\Facades\\SwissBankCsvParser"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
